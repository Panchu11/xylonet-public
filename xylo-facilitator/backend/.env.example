# XyloFacilitator Backend Environment
# Copy this file to .env and fill in the values

# ===== Server =====
PORT=3001
NODE_ENV=development
FACILITATOR_FEE_BPS=100

# ===== CORS =====
# Comma-separated list of allowed origin URLs
# In development (NODE_ENV=development): defaults to http://localhost:3000,http://localhost:3001
# In production (NODE_ENV=production): defaults to https://xylonet.xyz,https://www.xylonet.xyz
# Set this explicitly in production for custom domains
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ===== Security (REQUIRED in production) =====
JWT_SECRET=           # 64-char hex string for signing auth tokens
SETTLER_API_KEY=      # API key for settlement endpoint auth (X-Settler-Key header)

# ===== Arc Network =====
ARC_RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002

# ===== Wallet Keys (REQUIRED) =====
SETTLEMENT_PRIVATE_KEY=    # Private key for the settlement wallet (signs on-chain txs)
TREASURY_PRIVATE_KEY=      # Private key for the treasury wallet (receives fees)
MAIN_WALLET_ADDRESS=       # Public address of the main wallet

# ===== Contract Addresses =====
USDC_ADDRESS=0x3600000000000000000000000000000000000000
XYLOFACILITATOR_CONTRACT_ADDRESS=    # Deployed XyloFacilitator contract address

# ===== Supabase (REQUIRED) =====
SUPABASE_URL=              # Your Supabase project URL
SUPABASE_SERVICE_KEY=      # Supabase service role key (full access)
