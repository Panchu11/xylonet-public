# =============================================================================
# XyloNet Indexer — Production Environment Variables
# =============================================================================
# Copy this file to .env and replace placeholder values before deploying:
#   cp .env.production.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL 16
# ---------------------------------------------------------------------------
POSTGRES_USER=xylonet
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=xylonet_indexer
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Hasura GraphQL Engine
# ---------------------------------------------------------------------------
# Must match the postgres credentials above (uses internal Docker DNS)
HASURA_GRAPHQL_DATABASE_URL=postgres://xylonet:CHANGE_ME_TO_SECURE_PASSWORD@postgres:5432/xylonet_indexer
HASURA_GRAPHQL_ADMIN_SECRET=CHANGE_ME_TO_SECURE_SECRET

# ---------------------------------------------------------------------------
# Envio Indexer — PostgreSQL connection (internal Docker network)
# ---------------------------------------------------------------------------
ENVIO_PG_HOST=postgres
ENVIO_PG_PORT=5432
ENVIO_PG_USER=xylonet
ENVIO_PG_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
ENVIO_PG_DATABASE=xylonet_indexer

# ---------------------------------------------------------------------------
# Arc Testnet RPC
# ---------------------------------------------------------------------------
# Default: https://rpc.testnet.arc.network (hardcoded in config.yaml)
# Override here if using a private/faster RPC endpoint (e.g., Alchemy)
RPC_URL=https://rpc.testnet.arc.network
